  "item": [
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"product\": \"Laptop\",\n    \"quantity\": 2,\n    \"price\": 999.99,\n    \"customerName\": \"John Doe\",\n    \"customerEmail\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Create Multiple Orders",
